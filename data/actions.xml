<odoo>
    <!-- Actions for Users -->
    <record id="action_sync_image_from_user" model="ir.actions.server">
        <field name="name">Sync ID Photo from User</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">records.sync_id_photo()</field>
        <field name="binding_model_id" ref="base.model_res_users"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
    </record>

    <!-- Actions for Employees -->
    <record id="action_sync_image_from_employee" model="ir.actions.server">
        <field name="name">Sync ID Photos from Employee</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
        <field name="state">code</field>
        <field name="code">records.sync_id_photo()</field>
        <field name="binding_model_id" ref="hr.model_hr_employee"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
    </record>

    <!-- Actions for Contacts -->
    <record id="action_sync_image_from_partner" model="ir.actions.server">
        <field name="name">Sync ID Photo from Contact</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">records.sync_id_photo()</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
    </record>

    
</odoo>
