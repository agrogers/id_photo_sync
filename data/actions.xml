<odoo>
    <!-- Action for Users -->
    <record id="action_sync_image_user" model="ir.actions.server">
        <field name="name">Sync ID photos</field>
        <field name="model_id" ref="base.model_res_users"/>
        <field name="state">code</field>
        <field name="code">records.sync_images_between_user_employee_partner()</field>
        <field name="binding_model_id" ref="base.model_res_users"/>
        <field name="binding_type">action</field>
        <field name="binding_view_types">list,form</field>
    </record>

    <!-- Action for Employees -->
    <record id="action_sync_image_employee" model="ir.actions.server">
        <field name="name">Sync ID photos</field>
        <field name="model_id" ref="hr.model_hr_employee"/>
